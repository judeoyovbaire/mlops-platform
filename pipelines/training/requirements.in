# Direct dependencies for the training pipeline image.
# Human-edited. The installable lockfile (requirements.txt) is GENERATED:
#   uv pip compile pipelines/training/requirements.in \
#     --python-version 3.10 --python-platform x86_64-unknown-linux-gnu \
#     --generate-hashes --emit-index-url -o pipelines/training/requirements.txt
# CI fails if requirements.txt is stale relative to this file.
# pandas/scikit-learn/cloudpickle track seldonio/mlserver:1.7.1-mlflow (the
# KServe serving runtime, Python 3.10). The serving pyfunc is cloudpickled at
# training time and unpickled by MLServer - Python and pickle-critical
# library versions must match or the model fails to load (live failure:
# "code expected at most 16 arguments, got 18" = 3.12 pickle on 3.10).
pandas==2.2.3
scikit-learn==1.7.0
cloudpickle==3.1.1
mlflow==2.21.3
joblib==1.4.2
pandera==0.31.1
opentelemetry-api==1.30.0
opentelemetry-sdk==1.30.0
opentelemetry-exporter-otlp-proto-grpc==1.30.0
shap==0.46.0
# Resolver floor: without it, backtracking can select numba<=0.53
# (sdist-only, Python <3.10) and break the image build.
numba>=0.61
# MLflow S3 artifact uploads happen CLIENT-side - every image that logs
# artifacts needs boto3 (discovered live: training succeeded, artifact
